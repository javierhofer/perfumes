# ============================================
# DRIVER DE WHATSAPP (baileys | meta)
# ============================================
# Por default usa BAILEYS (WhatsApp Web, gratis, sin Meta).
# Para volver a Meta, ver bloque legacy al final.
WA_TRANSPORT=baileys

# ============================================
# BAILEYS (WhatsApp Web, gratis)
# ============================================
# Lista de chips en el pool: id:jid,id:jid
# Soporta N chips separados por coma (failover round-robin).
# jid: numero con codigo de pais, SIN el "+".
WA_PHONES=chip1:5492617629556

# Clave AES-256-GCM (32 bytes hex) para cifrar la sesion Baileys en disco.
# Generar: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
WA_SESSION_KEY=

# Numeros autorizados a usar el bot, separados por coma.
# Solo digitos con codigo de pais, SIN el "+".
# Vacio = rechaza todo (defensa en profundidad).
WA_ALLOWED_NUMBERS=

# Limites anti-baneo (opcionales, defaults razonables).
WA_MAX_PER_HOUR=30
WA_WARMUP_DAYS=0
WA_SHADOWBAN_THRESHOLD=0.3
# Numero al que avisar si el pool entero cae (canal de respaldo).
WA_BACKUP_CONTACT=

# ============================================
# LEGACY: ROLLBACK A META CLOUD API
# ============================================
# Si alguna vez queres volver a Meta, descomentar y completar:
#
# WA_TRANSPORT=meta
# WA_PHONE_ID=
# WA_TOKEN=
# WA_VERIFY_TOKEN=
# WA_APP_SECRET=
# WA_ALLOWED_NUMBERS=
