# ============================================
# DRIVER DE WHATSAPP (meta | baileys)
# ============================================
# Por default usa Meta Cloud API (oficial).
# Para rollback a Baileys (WhatsApp Web), ver seccion al final.
WA_TRANSPORT=meta

# ============================================
# META CLOUD API
# ============================================
# Phone Number ID (developers.facebook.com > App > WhatsApp > API Setup)
WA_PHONE_ID=

# Token de acceso. Temporal (24h) o System User Token (permanente).
WA_TOKEN=

# Verify Token del webhook (vos lo inventas, ej: perfumes-tovo-2026).
# Tiene que coincidir con el que cargues en Meta > Webhook.
WA_VERIFY_TOKEN=

# App Secret (Settings > Basic > App Secret).
# Recomendado para validar firma HMAC de los webhooks.
WA_APP_SECRET=

# Numeros autorizados a usar el bot, separados por coma.
# Solo digitos con codigo de pais, SIN el "+".
# Vacio = rechaza todo (defensa en profundidad).
WA_ALLOWED_NUMBERS=

# ============================================
# ROLLBACK A BAILEYS (WhatsApp Web sin Meta)
# ============================================
# Solo se usan si WA_TRANSPORT=baileys.

# Lista de chips: id:jid,id:jid (numero con codigo de pais, sin +)
# WA_PHONES=chip1:5491111111111

# Driver baileys (sin Meta). No usar con Meta cargado.
# WA_TRANSPORT=baileys

# Clave de cifrado de la sesion Baileys (32 bytes hex).
# Generar: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# WA_SESSION_KEY=

# Limites anti-baneo (solo Baileys)
# WA_MAX_PER_HOUR=30
# WA_WARMUP_DAYS=14