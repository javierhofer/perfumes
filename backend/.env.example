# ============================================
# INTEGRACION WHATSAPP CLOUD API (Meta)
# ============================================
# Estas variables se cargan en Render > Environment.
# En local, podes usar este archivo copiandolo a backend/.env
#
# Para obtener las credenciales:
#   https://developers.facebook.com/apps > Tu App > WhatsApp > API Setup

# ID del numero de telefono de WhatsApp Business (el numero de test o el de produccion)
WA_PHONE_ID=

# Token de acceso. Puede ser un "Temporary access token" (24h) o un System User Token (permanente).
WA_TOKEN=

# Token de verificacion que vos inventas (cualquier string). Cargalo tambien en Meta > Webhook > Verify Token.
WA_VERIFY_TOKEN=

# App Secret de la app de Meta (Settings > Basic > App Secret).
# Si lo dejas vacio, no se valida la firma HMAC (NO recomendado en produccion).
WA_APP_SECRET=

# Numeros de WhatsApp que pueden usar el bot, separados por coma.
# Formato: codigo de pais + numero, SIN el "+" (ej: 5491145551234).
# Si lo dejas vacio, TODOS los mensajes seran rechazados.
WA_ALLOWED_NUMBERS=
